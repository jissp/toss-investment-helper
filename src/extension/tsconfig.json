{
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ESNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "baseUrl": "../..",
        "paths": {
            "@app/*": ["src/app/*"],
            "@assets/*": ["src/assets/*"],
            "@common/*": ["src/common/*"],
            "@modules/*": ["src/modules/*"],
            "@extension/*": ["src/extension/*"]
        }
    }
}
